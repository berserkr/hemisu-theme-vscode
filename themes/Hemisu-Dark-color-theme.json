  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#777777",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#B1D631"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.operator.expression", "keyword.operator.logical", "keyword.operator.delete"],
      "settings": {
        "foreground": "#B1D631",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["storage.type", "storage.modifier", "keyword.type"],
      "settings": {
        "foreground": "#BBFFAA"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "entity.name.struct", "entity.name.enum", "entity.name.union", "entity.name.interface", "support.type", "support.class"],
      "settings": {
        "foreground": "#BBFFAA"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#EEEEEE",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#EEEEEE"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#9FD3E6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#BBFFAA"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["punctuation", "meta.brace", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.comparison"],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "scope": ["support.constant", "constant.other.color"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["entity.name.module", "entity.name.namespace", "entity.name.package"],
      "settings": {
        "foreground": "#EEEEEE"
      }
    },
    {
      "scope": ["meta.preprocessor", "keyword.control.directive", "keyword.control.import", "keyword.control.from"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#ECE1C8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline", "markup.underline.link"],
      "settings": {
        "foreground": "#9FD3E6",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code", "markup.raw"],
      "settings": {
        "foreground": "#B1D631"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#B1D631"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#D65E76"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#999999"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#777777",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#EEEEEE",
        "background": "#63001C"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#EEEEEE",
        "background": "#503D15"
      }
    },
    {
      "scope": ["comment.line.todo", "keyword.todo", "storage.type.class.todo"],
      "settings": {
        "foreground": "#D65E76",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["punctuation.definition.string", "string punctuation.section"],
      "settings": {
        "foreground": "#B1D631"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#BBFFAA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["meta.property-name", "support.type.property-name"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["meta.object-literal.key"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["support.type.vendored.property-name", "support.type.property-name"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#BBFFAA"
      }
    },
    {
      "scope": ["meta.selector"],
      "settings": {
        "foreground": "#BBFFAA"
      }
    },
    {
      "scope": ["source.json string.quoted.double.json meta.structure.dictionary.json"],
      "settings": {
        "foreground": "#9FD3E6"
      }
    },
    {
      "scope": ["source.json string.quoted.double.json meta.structure.dictionary.value.json string.quoted.double.json"],
      "settings": {
        "foreground": "#B1D631"
      }
    },
    {
      "scope": ["entity.name.label"],
      "settings": {
        "foreground": "#ECE1C8"
      }
    },
    {
      "scope": ["meta.type.annotation", "meta.return.type"],
      "settings": {
        "foreground": "#BBFFAA"
      }
    },
    {
      "scope": ["punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#777777"
      }
    }
  ],
  "semanticTokenColors": {
    "type": "#BBFFAA",
    "class": "#BBFFAA",
    "struct": "#BBFFAA",
    "interface": "#BBFFAA",
    "enum": "#BBFFAA",
    "enumMember": "#9FD3E6",
    "function": { "foreground": "#EEEEEE", "bold": true },
    "method": { "foreground": "#EEEEEE", "bold": true },
    "variable": "#EEEEEE",
    "variable.readonly": "#9FD3E6",
    "parameter": "#EEEEEE",
    "property": "#EEEEEE",
    "namespace": "#EEEEEE",
    "keyword": { "foreground": "#B1D631", "bold": true },
    "string": "#B1D631",
    "number": "#9FD3E6",
    "comment": { "foreground": "#777777", "italic": true }
  }
}

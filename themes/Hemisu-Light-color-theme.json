  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#999999",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#739200"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["keyword", "keyword.control", "keyword.operator.new", "keyword.operator.expression", "keyword.operator.logical", "keyword.operator.delete"],
      "settings": {
        "foreground": "#739200",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["storage.type", "storage.modifier", "keyword.type"],
      "settings": {
        "foreground": "#FF0055"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "entity.name.struct", "entity.name.enum", "entity.name.union", "entity.name.interface", "support.type", "support.class"],
      "settings": {
        "foreground": "#FF0055"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#111111",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["variable", "variable.other", "variable.parameter"],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": ["variable.language"],
      "settings": {
        "foreground": "#538192",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#FF0055"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["punctuation", "meta.brace", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#777777"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.arithmetic", "keyword.operator.comparison"],
      "settings": {
        "foreground": "#777777"
      }
    },
    {
      "scope": ["support.constant", "constant.other.color"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["entity.name.module", "entity.name.namespace", "entity.name.package"],
      "settings": {
        "foreground": "#111111"
      }
    },
    {
      "scope": ["meta.preprocessor", "keyword.control.directive", "keyword.control.import", "keyword.control.from"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["markup.heading", "entity.name.section"],
      "settings": {
        "foreground": "#503D15",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline", "markup.underline.link"],
      "settings": {
        "foreground": "#538192",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code", "markup.raw"],
      "settings": {
        "foreground": "#739200"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#739200"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#FF0055"
      }
    },
    {
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#777777"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#999999",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#FFFFFF",
        "background": "#FFAFAF"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#111111",
        "background": "#ECE1C8"
      }
    },
    {
      "scope": ["comment.line.todo", "keyword.todo", "storage.type.class.todo"],
      "settings": {
        "foreground": "#FF0055",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["punctuation.definition.string", "string punctuation.section"],
      "settings": {
        "foreground": "#739200"
      }
    },
    {
      "scope": ["entity.other.inherited-class"],
      "settings": {
        "foreground": "#FF0055",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["meta.property-name", "support.type.property-name"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["meta.object-literal.key"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["support.type.vendored.property-name", "support.type.property-name"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": {
        "foreground": "#FF0055"
      }
    },
    {
      "scope": ["meta.selector"],
      "settings": {
        "foreground": "#FF0055"
      }
    },
    {
      "scope": ["source.json string.quoted.double.json meta.structure.dictionary.json"],
      "settings": {
        "foreground": "#538192"
      }
    },
    {
      "scope": ["source.json string.quoted.double.json meta.structure.dictionary.value.json string.quoted.double.json"],
      "settings": {
        "foreground": "#739200"
      }
    },
    {
      "scope": ["entity.name.label"],
      "settings": {
        "foreground": "#503D15"
      }
    },
    {
      "scope": ["meta.type.annotation", "meta.return.type"],
      "settings": {
        "foreground": "#FF0055"
      }
    },
    {
      "scope": ["punctuation.separator", "punctuation.terminator"],
      "settings": {
        "foreground": "#999999"
      }
    }
  ],
  "semanticTokenColors": {
    "type": "#FF0055",
    "class": "#FF0055",
    "struct": "#FF0055",
    "interface": "#FF0055",
    "enum": "#FF0055",
    "enumMember": "#538192",
    "function": { "foreground": "#111111", "bold": true },
    "method": { "foreground": "#111111", "bold": true },
    "variable": "#111111",
    "variable.readonly": "#538192",
    "parameter": "#111111",
    "property": "#111111",
    "namespace": "#111111",
    "keyword": { "foreground": "#739200", "bold": true },
    "string": "#739200",
    "number": "#538192",
    "comment": { "foreground": "#999999", "italic": true }
  }
}
